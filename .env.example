# HuggingFace (embeddings)
HF_TOKEN=your_hf_token

# Groq LLM
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.1-8b-instant

# PostgreSQL (use same values in docker-compose)
POSTGRES_DB=ai_doc_rag
POSTGRES_USER=rag_admin
POSTGRES_PASSWORD=super_secure_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://rag_admin:super_secure_password@db:5432/ai_doc_rag

# JWT
JWT_SECRET_KEY=generate_a_long_random_secret_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Storage (per-user files and vectors)
STORAGE_PATH=/app/storage
